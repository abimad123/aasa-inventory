# Neon PostgreSQL Connection String (must end with ?sslmode=require for secure Neon connection)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth.js Secret Key (random 32-character string used to hash tokens)
NEXTAUTH_SECRET="your-32-character-secret-key"

# NextAuth.js Canonical App URL (use http://localhost:3000 for local development, or your Vercel deployment URL for production)
NEXTAUTH_URL="http://localhost:3000"

