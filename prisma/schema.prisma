// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Role of the user within the system
enum Role {
  ADMIN
  SELLER
}

/// Supported physical units for products and transaction items
enum Unit {
  G      // grams (base unit for weight)
  KG     // kilograms (converted to G internally: 1 KG = 1000 G)
  ML     // milliliters (base unit for volume)
  L      // liters (converted to ML internally: 1 L = 1000 ML)
  ITEM   // item (base unit for count)
}

/// Lifecycle status of a Quotation
enum QuotationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CONVERTED
}

/// Lifecycle status of an Order
enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

/// Type of Inventory Transaction for stock tracking
enum InventoryTransactionType {
  IN          // Stock added (e.g., purchases, returns)
  OUT         // Stock removed (e.g., sales, waste)
  ADJUSTMENT  // Stock corrected manually (e.g., stocktaking discrepancy)
}

/// User model representing administrators and sellers.
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hashed password string
  role      Role     @default(SELLER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  quotations Quotation[]
  orders     Order[]

  @@map("users")
}

/// Product model representing items in stock.
/// Inventory levels (stockQuantity) and unit pricing (pricePerBaseUnit)
/// are always stored and tracked in the designated baseUnit (G, ML, or ITEM).
model Product {
  id               String   @id @default(uuid())
  sku              String   @unique
  name             String
  description      String?
  category         String
  baseUnit         Unit     // Must belong to base units: G, ML, or ITEM
  pricePerBaseUnit Decimal  @db.Decimal(12, 2) // Price per single base unit (e.g. price per 1 gram)
  stockQuantity    Decimal  @db.Decimal(12, 4) // Current stock tracked in base units
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  quotationItems       QuotationItem[]
  orderItems           OrderItem[]
  inventoryTransactions InventoryTransaction[]

  @@map("products")
}

/// Quotation model representing price estimation drafts generated by users.
model Quotation {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id])
  status      QuotationStatus @default(DRAFT)
  totalAmount Decimal         @db.Decimal(12, 2) @map("total_amount")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  items QuotationItem[]

  @@map("quotations")
}

/// QuotationItem representing a line-item inside a quotation.
model QuotationItem {
  id                String    @id @default(uuid())
  quotationId       String    @map("quotation_id")
  quotation         Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId         String    @map("product_id")
  product           Product   @relation(fields: [productId], references: [id])
  enteredQuantity   Decimal   @db.Decimal(12, 4) @map("entered_quantity") // e.g. 2.5
  enteredUnit       Unit      @map("entered_unit") // e.g. KG
  convertedQuantity Decimal   @db.Decimal(12, 4) @map("converted_quantity") // e.g. 2500.0000 (if product base unit is G)
  unitPrice         Decimal   @db.Decimal(12, 2) @map("unit_price") // unit price matching the entered unit at the time of quotation
  lineTotal         Decimal   @db.Decimal(12, 2) @map("line_total") // enteredQuantity * unitPrice
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("quotation_items")
}

/// Order model representing finalized transactions.
model Order {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(12, 2) @map("total_amount")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  items OrderItem[]

  @@map("orders")
}

/// OrderItem representing a line-item inside a finalized order.
model OrderItem {
  id                String   @id @default(uuid())
  orderId           String   @map("order_id")
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String   @map("product_id")
  product           Product  @relation(fields: [productId], references: [id])
  enteredQuantity   Decimal  @db.Decimal(12, 4) @map("entered_quantity") // e.g. 1.5
  enteredUnit       Unit     @map("entered_unit") // e.g. L
  convertedQuantity Decimal  @db.Decimal(12, 4) @map("converted_quantity") // e.g. 1500.0000 (if product base unit is ML)
  unitPrice         Decimal  @db.Decimal(12, 2) @map("unit_price") // unit price matching the entered unit at the time of order
  lineTotal         Decimal  @db.Decimal(12, 2) @map("line_total") // enteredQuantity * unitPrice
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("order_items")
}

/// InventoryTransaction model for auditing stock changes and tracking historical stock level movements.
model InventoryTransaction {
  id        String                   @id @default(uuid())
  productId String                   @map("product_id")
  product   Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      InventoryTransactionType
  quantity  Decimal                  @db.Decimal(12, 4) // Transaction quantity always represented in the product's base unit
  notes     String?
  createdAt DateTime                 @default(now()) @map("created_at")
  updatedAt DateTime                 @updatedAt @map("updated_at")

  @@map("inventory_transactions")
}
