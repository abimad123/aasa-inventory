generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// User model representing administrators and sellers.
model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(SELLER)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  orders     Order[]
  quotations Quotation[]

  @@map("users")
}

/// Product model representing items in stock.
/// Inventory levels (stockQuantity) and unit pricing (pricePerBaseUnit)
/// are always stored and tracked in the designated baseUnit (G, ML, or ITEM).
model Product {
  id                    String                 @id @default(uuid())
  sku                   String                 @unique
  name                  String
  description           String?
  category              String
  baseUnit              Unit
  pricePerBaseUnit      Decimal                @db.Decimal(12, 2)
  stockQuantity         Decimal                @db.Decimal(12, 4)
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  inventoryTransactions InventoryTransaction[]
  orderItems            OrderItem[]
  quotationItems        QuotationItem[]

  @@map("products")
}

/// Quotation model representing price estimation drafts generated by users.
model Quotation {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  status      QuotationStatus @default(DRAFT)
  totalAmount Decimal         @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  items       QuotationItem[]
  user        User            @relation(fields: [userId], references: [id])

  @@map("quotations")
}

/// QuotationItem representing a line-item inside a quotation.
model QuotationItem {
  id                String    @id @default(uuid())
  quotationId       String    @map("quotation_id")
  productId         String    @map("product_id")
  enteredQuantity   Decimal   @map("entered_quantity") @db.Decimal(12, 4)
  enteredUnit       Unit      @map("entered_unit")
  convertedQuantity Decimal   @map("converted_quantity") @db.Decimal(12, 4)
  unitPrice         Decimal   @map("unit_price") @db.Decimal(12, 2)
  lineTotal         Decimal   @map("line_total") @db.Decimal(12, 2)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  product           Product   @relation(fields: [productId], references: [id])
  quotation         Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

/// Order model representing finalized transactions.
model Order {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  items       OrderItem[]
  user        User        @relation(fields: [userId], references: [id])

  @@map("orders")
}

/// OrderItem representing a line-item inside a finalized order.
model OrderItem {
  id                String   @id @default(uuid())
  orderId           String   @map("order_id")
  productId         String   @map("product_id")
  enteredQuantity   Decimal  @map("entered_quantity") @db.Decimal(12, 4)
  enteredUnit       Unit     @map("entered_unit")
  convertedQuantity Decimal  @map("converted_quantity") @db.Decimal(12, 4)
  unitPrice         Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal         Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

/// InventoryTransaction model for auditing stock changes and tracking historical stock level movements.
model InventoryTransaction {
  id        String                   @id @default(uuid())
  productId String                   @map("product_id")
  type      InventoryTransactionType
  quantity  Decimal                  @db.Decimal(12, 4)
  notes     String?
  createdAt DateTime                 @default(now()) @map("created_at")
  updatedAt DateTime                 @updatedAt @map("updated_at")
  product   Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

/// Role of the user within the system
enum Role {
  ADMIN
  SELLER
}

/// Supported physical units for products and transaction items
enum Unit {
  G
  KG
  ML
  L
  ITEM
}

/// Lifecycle status of a Quotation
enum QuotationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CONVERTED
}

/// Lifecycle status of an Order
enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

/// Type of Inventory Transaction for stock tracking
enum InventoryTransactionType {
  IN
  OUT
  ADJUSTMENT
}
